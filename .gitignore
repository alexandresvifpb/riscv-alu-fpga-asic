# ============================================
# Gitignore para Projetos ASIC/FPGA
# ============================================

# Simulação (arquivos gerados)
*.vvp
*.vcd
*.fst
*.fsdb
*.shm
*.wlf
*.ghw
*.vpd
*.trn
sim/rtl/
sim/gl/
sim/waves/

# Logs e temporários
*.log
*.tmp
*.bak
*.backup
*~
*.swp
*.swo

# FPGA - Quartus (arquivos gerados)
fpga/quartus/output_files/
fpga/quartus/db/
fpga/quartus/incremental_db/
fpga/bitstream/
fpga/quartus/*.bak

# FPGA - Vivado (se usado)
fpga/vivado/*.log
fpga/vivado/.Xil/
fpga/vivado/*.wdb

# ASIC (arquivos gerados)
asic/netlist/
asic/reports/
asic/logs/
asic/def/
asic/odb/
asic/gds/
asic/magic/

# Backend (arquivos gerados)
backend/def/
backend/odb/
backend/gds/
backend/netlist/
backend/reports/
backend/logs/

# Formal verification (arquivos gerados)
formal/netlist/
formal/reports/

# Documentação compilada
docs/**/*.pdf
docs/**/*.aux
docs/**/*.log

# Editor
.vscode/
.idea/
*.sublime-*

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# ============================================
# EXCEÇÕES - Arquivos importantes
# ============================================

# Netlist do frontend (resultado da síntese)
!frontend/netlist/*.v

# Relatórios do frontend
!frontend/reports/*.rpt
!frontend/reports/*.json
!frontend/reports/*.dot
!frontend/reports/*.png
!frontend/reports/*.pdf
!frontend/reports/synth_frontend.log

# Relatórios da formal

# Scripts e constraints
!*.tcl
!*.ys
!*.qsf
!*.qpf
!*.sdc
!*.xdc

# Mantém diretórios vazios
!.gitkeep


